@page
@using ViPet_opgave_U12_13
@model ViPet_WebApplication.Pages.backlogModel
@{
}

<h1>PRODUCT BACKLOG</h1>
<center><button type="button" class="btn">Create Userstory</button></center>
<div class="row">
	<table class="table table-hover"> 
		<thead>
			<tr>
				<th>Name</th>
				<th>ID</th>
				<th></th>
				<th></th>
			</tr>
		</thead>
	<tbody>
		<form method="post">
			@foreach (Userstory u in Model.Backlogs.Product.ListAll())
		{
				
			<tr>
				
					
					<td> <a class="nav-link text-dark" asp-area="" asp-page="/Userstory"> @u.Name </a></td>

					<td> <a class="nav-link text-dark" asp-area="" asp-page="/Userstory"> @u.Id </a></td>
					<td><input type="submit" asp-page-handler="Delete" asp-route-id="@u.Id" value="Delete Userstory" /></td>
					<td><input type="submit" asp-page-handler="Move" asp-route-id="@u.Id" value="Move Userstory" /></td>
			</tr>
			
		}
			</form>
	</tbody>
	</table>
</div>